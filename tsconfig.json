{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./dist",
        "rootDir": ".",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "*": ["*"]
        }
    },
    "include": [
        "config/**/*.ts",
        "models/**/*",
        "routes/**/*",
        "services/**/*",
        "types/**/*.d.ts",
        "index.ts"
    ],
    "exclude": [
        "node_modules",
        "client",
        "dist"
    ]
}