{
  "name": "joonyrealestate-server",
  "version": "0.1.0",
  "description": "Joony Real Estate backend API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "server": "nodemon dist/index.js",
    "server:watch": "tsc --watch",
    "dev": "concurrently \"npm run server:watch\" \"npm run server\"",
    "legacy:export": "node scripts/exportSqlData2.js",
    "legacy:transform": "node scripts/transformBuildings.js",
    "legacy:stage": "MIGRATION_NUKE_OK=YES npx tsx scripts/importBuildings.ts",
    "legacy:normalize": "NORMALIZE_NUKE_OK=YES npx tsx scripts/normalizeBuildingsToCollections.ts",
    "legacy:verify": "npx tsx scripts/verifyNormalizedData.js",
    "legacy:import": "bash scripts/migrate-all.sh",
    "account:bootstrap:dneth": "npx tsx scripts/bootstrapAccountPhase1.ts",
    "account:backfill:operational": "npx tsx scripts/bootstrapAccountPhase2.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.731.0",
    "@aws-sdk/client-ses": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.731.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "concurrently": "^7.6.0",
    "cookie-session": "^2.0.0",
    "dayjs": "^1.11.20",
    "dotenv": "^16.5.0",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "express-useragent": "^1.0.15",
    "fs": "^0.0.1-security",
    "jquery": "^3.6.4",
    "jsdom": "^21.1.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.6.4",
    "mongoose": "^7.0.1",
    "mssql": "^11.0.1",
    "nodemon": "^2.0.21",
    "passport": "^0.5.3",
    "passport-2fa-totp": "^0.0.1",
    "passport-local": "^1.0.0",
    "request": "^2.88.2",
    "save": "^2.9.0",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
